---
import { Font } from "astro:assets";

import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pageClass?: string;
}

const { title, description, pageClass = "" } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === "/";
const isAbout = pathname.startsWith("/about");
const isWork = pathname.startsWith("/work");
const isWriting = pathname.startsWith("/writing");
const isNotFound = pathname.startsWith("/404");
const canonicalUrl = new URL(isNotFound ? "/404.html" : pathname, Astro.site ?? Astro.url.origin);
const robots = isNotFound ? "noindex, follow" : "index, follow";
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://vitalijhein.github.io/#vitalij-hein",
  name: "Vitalij Hein",
  url: "https://vitalijhein.github.io/",
  image: "https://vitalijhein.github.io/vitalij-hein-portrait.webp",
  jobTitle: "AI Engineer and Software Architect",
  description:
    "AI Engineer and Software Architect building production AI and software systems for difficult customer problems from discovery through delivery.",
  worksFor: {
    "@type": "Organization",
    name: "Reply",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "TU Wien",
  },
  knowsAbout: [
    "AI engineering",
    "Software architecture",
    "Agentic Engineering",
    "Microsoft Azure",
    "Python",
    "C#",
    "Retrieval systems",
    "Automated software testing",
  ],
  sameAs: [
    "https://www.linkedin.com/in/vitalijhein",
    "https://github.com/vitalijhein",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#07111f" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vitalij Hein" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://vitalijhein.github.io/vitalij-hein-portrait.webp" />
    <meta property="og:image:width" content="900" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="Portrait of Vitalij Hein" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://vitalijhein.github.io/vitalij-hein-portrait.webp" />
    <meta name="twitter:image:alt" content="Portrait of Vitalij Hein" />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <div class="shell header-inner">
        <a class="wordmark" href="/" aria-label="VH, Vitalij Hein, home">
          <span class="wordmark-mark" aria-hidden="true">VH</span>
          <span>Vitalij Hein</span>
        </a>

        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/" aria-current={isHome ? "page" : undefined}>Home</a>
          <a href="/work/" aria-current={isWork ? "page" : undefined}>Work</a>
          <a href="/writing/" aria-current={isWriting ? "page" : undefined}>Writing</a>
          <a href="/about/" aria-current={isAbout ? "page" : undefined}>About</a>
          <a
            class="nav-external"
            href="https://www.linkedin.com/in/vitalijhein"
            target="_blank"
            rel="noreferrer"
          >
            LinkedIn <span aria-hidden="true">↗</span>
          </a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <p class="footer-kicker">Have a difficult system to build?</p>
          <a class="footer-email" href="mailto:vitalijhein@googlemail.com">
            vitalijhein@googlemail.com
          </a>
        </div>

        <div class="footer-links" aria-label="External links">
          <a href="https://www.linkedin.com/in/vitalijhein" target="_blank" rel="noreferrer">LinkedIn ↗</a>
          <a href="https://github.com/vitalijhein" target="_blank" rel="noreferrer">GitHub ↗</a>
          <a href="/work/">Case studies →</a>
          <a href="/writing/">Writing →</a>
        </div>

        <p class="footer-note">AI engineering · software architecture · hands-on delivery</p>
      </div>
    </footer>
  </body>
</html>
