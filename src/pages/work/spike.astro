---
import { getCollection, render } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const cases = await getCollection("cases");
const entry = cases.find(({ id }) => id === "voice-agent-regression-testing");

if (!entry) {
  throw new Error("Canonical voice-agent case study was not loaded");
}

if (cases.length !== 6) {
  throw new Error(`Expected six canonical case studies, received ${cases.length}`);
}

const { Content, headings } = await render(entry);
---

<BaseLayout
  title="Voice-Agent Regression Testing | Vitalij Hein"
  description="Canonical case-study rendering spike for the automated voice-agent regression framework."
>
  <article class="shell section">
    <p class="eyebrow">Canonical content spike / {cases.length} cases / {headings.length} sections</p>
    <Content />
  </article>
</BaseLayout>
